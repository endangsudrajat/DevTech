:root {
    --bg-color: #0d0d0d;
    --card-bg: #161616;
    --text-primary: #ffffff;
    --text-secondary: #8a8a8a;
    --accent: #222222;
    --border-radius: 28px;
    --card-padding: 30px;
    --font-main: 'Inter', sans-serif;
    --font-heading: 'Outfit', sans-serif;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-main);
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding: 20px;
    overflow-x: hidden;
}

.bento-container {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: minmax(100px, auto);
    gap: 16px;
    max-width: 1200px;
    width: 100%;
}

.card {
    background-color: var(--card-bg);
    border-radius: var(--border-radius);
    padding: var(--card-padding);
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, background-color 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    flex-direction: column;
}

/* Row 1 */
.hero-card {
    grid-column: span 5;
    grid-row: span 2;
    justify-content: center;
}

#app1 {
    grid-column: span 2;
    grid-row: span 2;
    height: 320px;
}

#app2 {
    grid-column: span 2;
    grid-row: span 2;
    height: 320px;
}

.socials-wrapper {
    grid-column: span 3;
    grid-row: span 2;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: 12px;
}

/* Row 2 */
#profile {
    grid-column: span 2;
    grid-row: span 2;
    height: 380px;
}

.about-card {
    grid-column: span 3;
    grid-row: span 2;
    height: 380px;
    justify-content: space-between;
}

#laptop {
    grid-column: span 4;
    grid-row: span 2;
    height: 380px;
}

.resources-card {
    grid-column: span 3;
    grid-row: span 3;
    justify-content: flex-start;
}

/* Row 3 */
#newsletter {
    grid-column: span 4;
    grid-row: span 2;
    justify-content: center;
}

#stack {
    grid-column: span 2;
    grid-row: span 2;
    justify-content: space-between;
}

#mode-toggle {
    grid-column: span 2;
    grid-row: span 2;
    justify-content: center;
}

#contact {
    grid-column: span 2;
    grid-row: span 2;
    justify-content: space-between;
}

.label {
    text-transform: uppercase;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-secondary);
    letter-spacing: 1.5px;
    margin-bottom: 20px;
    display: block;
}

.about-text {
    font-size: 1.5rem;
    line-height: 1.3;
    font-weight: 500;
    color: var(--text-primary);
}

.arrow-btn {
    position: absolute;
    bottom: 25px;
    right: 25px;
    width: 36px;
    height: 36px;
    background-color: var(--accent);
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 0.9rem;
    cursor: pointer;
    transition: transform 0.3s ease;
}

.arrow-btn:hover {
    transform: scale(1.1);
}

#laptop {
    grid-column: span 2;
}

.resources-card {
    grid-column: 5;
    display: flex;
    flex-direction: column;
}

.card-title {
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.4;
}

.arrow-btn-bottom {
    margin-top: auto;
    width: 36px;
    height: 36px;
    background-color: var(--accent);
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-left: auto;
    cursor: pointer;
}

/* Bottom Row */
.newsletter-card {
    grid-column: span 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.newsletter-title {
    font-size: 1.2rem;
    font-weight: 500;
    margin-bottom: 20px;
}

.newsletter-form {
    display: flex;
    gap: 10px;
    background-color: #0b0b0b;
    padding: 6px;
    border-radius: 16px;
}

.email-input {
    flex-grow: 1;
    background: transparent;
    border: none;
    color: white;
    padding: 10px 15px;
    font-family: inherit;
    outline: none;
}

.submit-btn {
    background-color: var(--accent);
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 12px;
    cursor: pointer;
    font-weight: 500;
    transition: background-color 0.2s;
}

.submit-btn:hover {
    background-color: #333;
}

.stack-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.stack-icons {
    display: flex;
    gap: 12px;
}

.stack-icon {
    width: 44px;
    height: 44px;
    background-color: #0b0b0b;
    border-radius: 12px;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 1.4rem;
}

.toggle-card {
    display: flex;
    justify-content: center;
    align-items: center;
}

.toggle-switch {
    cursor: pointer;
}

.toggle-track {
    width: 60px;
    height: 32px;
    background-color: var(--accent);
    border-radius: 20px;
    position: relative;
    padding: 4px;
}

.toggle-thumb {
    width: 24px;
    height: 24px;
    background-color: #3a3a3a;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 0.8rem;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform: translateX(28px);
}

.contact-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.card-title-small {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-secondary);
}

.copy-email-btn {
    background-color: var(--accent);
    color: var(--text-primary);
    border: none;
    padding: 12px;
    border-radius: 14px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.9rem;
    margin-top: 15px;
}

.copy-email-btn:hover {
    background-color: #333;
}

/* Responsive */
@media (max-width: 1024px) {
    .bento-container {
        grid-template-columns: repeat(4, 1fr);
    }

    .resources-card,
    .socials-wrapper,
    .contact-card {
        grid-column: span 1;
    }
}

@media (max-width: 768px) {
    .bento-container {
        grid-template-columns: repeat(2, 1fr);
    }

    .hero-card,
    .laptop-img,
    .newsletter-card {
        grid-column: span 2;
    }

    #laptop {
        grid-column: span 2;
    }
}

@media (max-width: 480px) {
    .bento-container {
        grid-template-columns: 1fr;
    }

    .card,
    .hero-card,
    .newsletter-card,
    #laptop,
    .socials-wrapper {
        grid-column: span 1;
    }
}